<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="E_Commerce.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:E_Commerce"
    xmlns:views="clr-namespace:E_Commerce.Views"
    Title="E_Commerce">

    <Shell.Resources>
        <ResourceDictionary>
            <Style TargetType="TabBar">
                <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource CardBackground}" />
                <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Primary}" />
                <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TextSecondary}" />
                <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource Primary}" />
            </Style>
        </ResourceDictionary>
    </Shell.Resources>

    <TabBar>
        <Tab Title="Home" Icon="dotnet_bot.png">
            <ShellContent
                Title="Home"
                ContentTemplate="{DataTemplate views:HomePage}"
                Route="HomePage" />
        </Tab>
        <Tab Title="Cart" Icon="dotnet_bot.png">
            <ShellContent
                Title="Cart"
                ContentTemplate="{DataTemplate views:CartPage}"
                Route="CartPage" />
        </Tab>
    </TabBar>

</Shell>
