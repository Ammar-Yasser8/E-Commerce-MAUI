<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:E_Commerce.ViewModels"
             x:Class="E_Commerce.Views.ProductDetailsPage"
             BackgroundColor="{StaticResource Background}"
             Shell.NavBarIsVisible="True"
             Title="Product Details">

    <ContentPage.BindingContext>
        <vm:ProductDetailsViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="*, Auto">

        <ScrollView Grid.Row="0">
            <StackLayout Spacing="0">

                <!-- ═══ Product Image ═══ -->
                <Frame HeightRequest="380" CornerRadius="0" Padding="0" HasShadow="False"
                       BackgroundColor="{StaticResource SecondaryBackground}">
                    <Image Source="{Binding Product.Image}" Aspect="AspectFill" />
                </Frame>

                <!-- ═══ Product Info Card ═══ -->
                <Frame Margin="0,-30,0,0" CornerRadius="30" Padding="0" HasShadow="True"
                       BackgroundColor="{StaticResource CardBackground}" BorderColor="Transparent">
                    <StackLayout Padding="24" Spacing="16">

                        <!-- Name + Price row -->
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                            <Label Text="{Binding Product.Name}" FontSize="22" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" Grid.ColumnSpan="2" />
                            <StackLayout Grid.Row="1" Orientation="Horizontal" Spacing="8">
                                <Label Text="{Binding Product.Price, StringFormat='${0:F2}'}"
                                       FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                                <Label Text="{Binding Product.OriginalPrice, StringFormat='${0:F2}'}"
                                       FontSize="14" TextColor="{StaticResource TextLight}"
                                       TextDecorations="Strikethrough" VerticalOptions="Center"
                                       IsVisible="{Binding Product.HasDiscount}" />
                            </StackLayout>
                            <Frame Grid.Row="1" Grid.Column="1" CornerRadius="12" Padding="8,4"
                                   HasShadow="False" BackgroundColor="{StaticResource Accent}"
                                   VerticalOptions="Center" IsVisible="{Binding Product.HasDiscount}">
                                <Label Text="{Binding Product.DiscountPercent}" FontSize="12"
                                       FontAttributes="Bold" TextColor="White" />
                            </Frame>
                        </Grid>

                        <!-- Rating -->
                        <Frame CornerRadius="12" Padding="12,8" HasShadow="False"
                               BackgroundColor="{StaticResource SecondaryBackground}" HorizontalOptions="Start">
                            <StackLayout Orientation="Horizontal" Spacing="6">
                                <Label Text="⭐" FontSize="16" VerticalOptions="Center" />
                                <Label Text="{Binding Product.Rating}" FontAttributes="Bold"
                                       FontSize="15" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Label Text="{Binding Product.ReviewCount, StringFormat='({0} reviews)'}"
                                       TextColor="{StaticResource TextSecondary}" FontSize="13" VerticalOptions="Center" />
                            </StackLayout>
                        </Frame>

                        <!-- Divider -->
                        <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,4" />

                        <!-- Description -->
                        <Label Text="Description" FontSize="17" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="{Binding Product.Description}" TextColor="{StaticResource TextSecondary}"
                               FontSize="14" LineHeight="1.6" />

                        <!-- Divider -->
                        <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,4" />

                        <!-- Quantity Picker -->
                        <Label Text="Quantity" FontSize="17" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Frame CornerRadius="14" Padding="4" HasShadow="False"
                               BackgroundColor="{StaticResource SecondaryBackground}"
                               HorizontalOptions="Start">
                            <StackLayout Orientation="Horizontal" Spacing="0">
                                <Button Text="−" WidthRequest="44" HeightRequest="44"
                                        CornerRadius="12" BackgroundColor="{StaticResource CardBackground}"
                                        TextColor="{StaticResource TextPrimary}" FontSize="20" FontAttributes="Bold"
                                        Command="{Binding DecreaseQuantityCommand}" />
                                <Label Text="{Binding Quantity}" FontSize="18" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       WidthRequest="50" HorizontalTextAlignment="Center"
                                       VerticalOptions="Center" />
                                <Button Text="+" WidthRequest="44" HeightRequest="44"
                                        CornerRadius="12" BackgroundColor="{StaticResource Primary}"
                                        TextColor="White" FontSize="20" FontAttributes="Bold"
                                        Command="{Binding IncreaseQuantityCommand}" />
                            </StackLayout>
                        </Frame>

                    </StackLayout>
                </Frame>
            </StackLayout>
        </ScrollView>

        <!-- ═══ Bottom Action Bar ═══ -->
        <Frame Grid.Row="1" Padding="20,16" BackgroundColor="{StaticResource CardBackground}"
               HasShadow="True" BorderColor="Transparent" CornerRadius="0">
            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="16">
                <Frame CornerRadius="16" Padding="0" WidthRequest="56" HeightRequest="56"
                       HasShadow="False" BackgroundColor="{StaticResource SecondaryBackground}"
                       BorderColor="{StaticResource Gray200}">
                    <Label Text="♡" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"
                           TextColor="{StaticResource TextPrimary}" />
                </Frame>
                <Button Grid.Column="1" Text="Add to Cart  🛒"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White" FontAttributes="Bold" FontSize="16"
                        CornerRadius="16" HeightRequest="56"
                        Command="{Binding AddToCartCommand}" />
            </Grid>
        </Frame>
    </Grid>

</ContentPage>
