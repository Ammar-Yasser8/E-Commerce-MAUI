<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:E_Commerce.ViewModels"
             xmlns:models="clr-namespace:E_Commerce.Models"
             x:Class="E_Commerce.Views.CartPage"
             BackgroundColor="{StaticResource Background}"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:CartViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- Custom Header -->
        <Grid Grid.Row="0" Padding="20,16" ColumnDefinitions="Auto, *, Auto" VerticalOptions="Start">
            <Button Text="←" 
                    FontSize="20"
                    WidthRequest="44" 
                    HeightRequest="44"
                    CornerRadius="22"
                    Padding="0"
                    BackgroundColor="{StaticResource SecondaryBackground}"
                    TextColor="{StaticResource TextPrimary}"
                    Command="{Binding GoBackCommand}"
                    IsVisible="True" />
            <!-- Note: Shell back navigation is tricky from binding. I will add a command to the ViewModel instead for better UX. -->
            
            <Label Grid.Column="1" Text="My Cart" FontSize="20" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center" VerticalOptions="Center" />
            
            <Button Grid.Column="2" Text="⋮" 
                    FontSize="20"
                    WidthRequest="44" 
                    HeightRequest="44"
                    CornerRadius="22"
                    Padding="0"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource TextPrimary}" />
        </Grid>

        <!-- ═══ Cart Items ═══ -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding CartItems}" Margin="16,8">

            <!-- Empty State -->
            <CollectionView.EmptyView>
                <StackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16" Padding="40">
                    <Frame CornerRadius="50" WidthRequest="100" HeightRequest="100" Padding="0"
                           HasShadow="False" BackgroundColor="{StaticResource SecondaryBackground}"
                           HorizontalOptions="Center">
                        <Label Text="🛒" FontSize="48" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Frame>
                    <Label Text="Your cart is empty" FontSize="22" FontAttributes="Bold"
                           HorizontalOptions="Center" TextColor="{StaticResource TextPrimary}" />
                    <Label Text="Looks like you haven't added&#10;anything to your cart yet."
                           HorizontalOptions="Center" TextColor="{StaticResource TextSecondary}"
                           HorizontalTextAlignment="Center" FontSize="14" LineHeight="1.4" />
                    <Button Text="Start Shopping" BackgroundColor="{StaticResource Primary}"
                            TextColor="White" CornerRadius="16" HeightRequest="52"
                            WidthRequest="200" Margin="0,10,0,0" FontAttributes="Bold" />
                </StackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CartItem">
                    <SwipeView Margin="0,0,0,12">
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Execute">
                                <SwipeItem Text="Delete" BackgroundColor="{StaticResource Danger}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CartViewModel}}, Path=RemoveItemCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Frame CornerRadius="20" HasShadow="True" Padding="12"
                               BackgroundColor="{StaticResource CardBackground}" BorderColor="Transparent">
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="14">
                                <!-- Image -->
                                <Frame Grid.Column="0" CornerRadius="14" Padding="0"
                                       HeightRequest="90" WidthRequest="90"
                                       HasShadow="False" BackgroundColor="{StaticResource SecondaryBackground}"
                                       BorderColor="Transparent">
                                    <Image Source="{Binding Product.Image}" Aspect="AspectFill" />
                                </Frame>
                                <!-- Info -->
                                <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="6">
                                    <Label Text="{Binding Product.Name}" FontAttributes="Bold" FontSize="15"
                                           TextColor="{StaticResource TextPrimary}"
                                           MaxLines="2" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Product.Price, StringFormat='${0:F2}'}"
                                           TextColor="{StaticResource Primary}" FontAttributes="Bold" FontSize="16" />
                                </StackLayout>
                                <!-- Qty Controls -->
                                <Frame Grid.Column="2" CornerRadius="14" Padding="4"
                                       HasShadow="False" BackgroundColor="{StaticResource SecondaryBackground}"
                                       VerticalOptions="Center" BorderColor="Transparent">
                                    <StackLayout Spacing="2">
                                        <Button Text="+" WidthRequest="36" HeightRequest="36"
                                                CornerRadius="10" BackgroundColor="{StaticResource Primary}"
                                                TextColor="White" FontSize="16" FontAttributes="Bold" Padding="0"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CartViewModel}}, Path=IncreaseCommand}"
                                                CommandParameter="{Binding .}" />
                                        <Label Text="{Binding Quantity}" FontSize="16" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"
                                               HorizontalTextAlignment="Center" Margin="0,4" />
                                        <Button Text="−" WidthRequest="36" HeightRequest="36"
                                                CornerRadius="10" BackgroundColor="{StaticResource CardBackground}"
                                                TextColor="{StaticResource TextPrimary}" FontSize="16"
                                                FontAttributes="Bold" Padding="0"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CartViewModel}}, Path=DecreaseCommand}"
                                                CommandParameter="{Binding .}" />
                                    </StackLayout>
                                </Frame>
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ═══ Order Summary & Checkout ═══ -->
        <Frame Grid.Row="2" Padding="24,20" BackgroundColor="{StaticResource CardBackground}"
               HasShadow="True" BorderColor="Transparent" CornerRadius="30">
            <Frame.Style>
                <Style TargetType="Frame">
                    <Setter Property="IsVisible" Value="True" />
                    <Style.Triggers>
                        <DataTrigger TargetType="Frame" Binding="{Binding IsCartEmpty}" Value="True">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Frame.Style>
            <StackLayout Spacing="12">
                <!-- Subtotal -->
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="Subtotal" FontSize="14" TextColor="{StaticResource TextSecondary}" />
                    <Label Grid.Column="1" Text="{Binding Subtotal, StringFormat='${0:F2}'}"
                           FontSize="14" TextColor="{StaticResource TextPrimary}" />
                </Grid>
                <!-- Shipping -->
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="Shipping" FontSize="14" TextColor="{StaticResource TextSecondary}" />
                    <Label Grid.Column="1" FontSize="14">
                        <Label.Style>
                            <Style TargetType="Label">
                                <Setter Property="Text" Value="{Binding Shipping, StringFormat='${0:F2}'}" />
                                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                                <Style.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Shipping}" Value="0">
                                        <Setter Property="Text" Value="FREE" />
                                        <Setter Property="TextColor" Value="{StaticResource Success}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Label.Style>
                    </Label>
                </Grid>
                <!-- Divider -->
                <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,4" />
                <!-- Total -->
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="Total" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                    <Label Grid.Column="1" Text="{Binding TotalAmount, StringFormat='${0:F2}'}"
                           FontSize="22" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                </Grid>
                <!-- Checkout Button -->
                <Button Text="Checkout  →" BackgroundColor="{StaticResource Primary}"
                        TextColor="White" FontAttributes="Bold" FontSize="16"
                        CornerRadius="16" HeightRequest="56" Margin="0,4,0,0"
                        Command="{Binding CheckoutCommand}" />
            </StackLayout>
        </Frame>
    </Grid>

</ContentPage>
